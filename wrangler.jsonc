{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keihi-keisan-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "keihi-prod",
      "database_id": "7f236a8d-4ac4-4192-bd8c-ff8decb6f352"
    }
  ],
  "r2_buckets": [
    {
      "binding": "RECEIPTS_BUCKET",
      "bucket_name": "keihi-receipts-prod"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "EXTRACTION_QUEUE",
        "queue": "keihi-extraction-prod"
      }
    ]
  },
  "vars": {
    "APP_STAGE": "production",
    "AI_PROVIDER": "gemini-2.5-flash",
    "MAX_UPLOAD_BYTES": "10485760",
    "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/2fa6adcfdfb20da6d3a68f7a43c178a9/keihi-prod/google-ai-studio"
  }
}
